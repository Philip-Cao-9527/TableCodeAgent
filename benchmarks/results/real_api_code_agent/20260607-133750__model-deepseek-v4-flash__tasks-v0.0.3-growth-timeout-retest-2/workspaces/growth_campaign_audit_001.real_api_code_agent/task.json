    "constraints": [
      "不要读取 expected.json。",
      "不要把结果包在 audit_results 下。",
      "answer.json 必须是合法 JSON。"
    ]
  },
  "output_contract": {
    "validation_mode": "pytest",
    "answer_json_required_keys": [
      "row_counts",
      "join_cardinality",
      "group_distribution",
      "smd_summary",
