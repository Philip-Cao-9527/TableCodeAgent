{
  "id": "credit_risk_scoring_001",
  "task_type": "credit_risk_scoring",
  "question": "对信贷申请样本进行风险评分 workflow：读取申请表，检查字段、缺失值、重复主键、异常年龄、贷后泄漏字段，构造最小特征处理说明，输出可解释的规则卡评分和业务规则校验。",
  "tables": {
    "applications": "applications.csv"
  },
  "scoring_config": {
    "key_columns": ["application_id"],
    "target_column": "default_90d",
    "time_column": "application_time",
    "required_columns": [
      "application_id",
      "user_id",
      "application_time",
      "loan_amount",
      "income",
      "age",
      "credit_score",
      "existing_debt",
      "employment_years",
      "default_90d"
    ],
    "numeric_features": [
      "loan_amount",
      "income",
      "age",
      "credit_score",
      "existing_debt",
      "employment_years"
    ],
    "categorical_features": ["region"],
    "leakage_columns": ["post_loan_collection_calls"]
  },
  "output_contract": {
    "validation_mode": "pytest",
    "answer_json_required_keys": [
      "row_counts",
      "field_summary",
      "data_quality",
      "feature_processing",
      "scoring_result",
      "business_rule_checks",
      "explanations",
      "warnings",
      "how_to_do_differently",
      "validation"
    ],
    "schema_description": "answer.json 顶层必须直接输出这些字段；评分可以使用可复现规则卡，不需要训练生产模型，也不能把 default_90d 或 post_loan_collection_calls 用作贷前评分特征。"
  }
}
